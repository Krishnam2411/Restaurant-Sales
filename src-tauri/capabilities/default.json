{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main",
    "receipt-preview"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-create",
    "core:webview:allow-create-webview-window",
    "dialog:default",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-write-text-file",
    "fs:allow-mkdir",
    "fs:allow-exists",
    {
      "identifier": "fs:scope",
      "allow": [
        "$DOCUMENT/aalsi chatore/Ledgers",
        "$DOCUMENT/aalsi chatore/Ledgers/**",
        "$APPDATA/com.aalsi.chatore.sales",
        "$APPDATA/com.aalsi.chatore.sales/**",
        "$DOCUMENT/**",
        "$DESKTOP/**",
        "$DOWNLOAD/**",
        "$HOME/**",
        "$PUBLIC/**"
      ]
    },
    "sql:allow-load",
    "sql:allow-execute",
    "sql:allow-select",
    "sql:allow-close",
    "updater:default"
  ]
}
